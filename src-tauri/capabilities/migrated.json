{
	"identifier": "migrated",
	"description": "permissions that were migrated from v1",
	"local": true,
	"windows": ["main"],
	"permissions": [
		"core:default",
		"fs:allow-read-file",
		"fs:allow-write-file",
		"fs:allow-read-dir",
		"fs:allow-mkdir",
		"fs:allow-remove",
		"fs:allow-write-text-file",
		"fs:allow-create",
		{
			"identifier": "fs:scope",
			"allow": ["**"]
		},
		"shell:allow-open",
		"dialog:allow-open",
		"dialog:allow-save",
		"dialog:allow-confirm",
		"dialog:default",
		"fs:default",
		"shell:default"
	]
}
